  examCategory        ExamCategory
  subjects            String[]
  gradeLevel          String[]
  language            String               @default("hi")
  priceInPaisa        Int                  @default(0)
  maxStudents         Int?
  isOnline            Boolean              @default(true)
  batchStartDate      DateTime?
  batchEndDate        DateTime?
  scheduleJson        Json?
  status              ContentStatus        @default(DRAFT)
  thumbnailUrl        String?
  introVideoUrl       String?
  syllabusJson        Json?
  enrolledCount       Int                  @default(0)
  isTrialRequired     Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  deletedAt           DateTime?
  assignments         assignments[]
  course_enrollments  course_enrollments[]
  coaching_institutes coaching_institutes? @relation(fields: [instituteId], references: [id])
  teacher_profiles    TeacherProfile       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  trial_bookings      trial_bookings[]

  @@index([batchStartDate])
  @@index([deletedAt])
  @@index([examCategory])
  @@index([instituteId])
  @@index([isOnline])
  @@index([status])
  @@index([teacherId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model current_affairs_articles {
  id            String         @id
  title         String
  summary       String
  bodyMd        String?
  sourceUrl     String?
  publishedDate DateTime
  audioUrl      String?
  examRelevance ExamCategory[]
  tags          String[]
  status        ContentStatus  @default(PUBLISHED)
  viewCount     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?

  @@index([deletedAt])
  @@index([examRelevance])
  @@index([publishedDate])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daf_entries {
  id                 String               @id
  studentId          String
  pdfUrl             String?
  knowledgeGraph     Json?
  extractionStatus   String               @default("PENDING")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?
  student_profiles   StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  interview_sessions interview_sessions[]

  @@index([deletedAt])
  @@index([extractionStatus])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model document_vault {
  id              String   @id
  userId          String
  docType         String
  s3Key           String
  encryptionKeyId String
  extractedFields Json?
  fileName        String?
  fileSize        Int?
  mimeType        String?
  isActive        Boolean  @default(true)
  uploadedAt      DateTime @default(now())
  updatedAt       DateTime
  users           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([userId, docType])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model exam_calendar_events {
  id                    String       @id
  examName              String
  examCategory          ExamCategory
  eventType             String
  eventDate             DateTime
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  notifyBeforeDays      Int[]
  officialUrl           String?
  iCalString            String?
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime
  deletedAt             DateTime?

  @@index([deletedAt])
  @@index([eventDate])
  @@index([eventType])
  @@index([examCategory])
  @@index([isActive])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model form_autofill_templates {
  id             String       @id
  examName       String
  examCategory   ExamCategory
  formUrl        String?
  selectorConfig Json
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime

  @@index([examCategory])
  @@index([isActive])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model free_resources {
  id            String           @id
  title         String
  description   String?
  resourceType  FreeResourceType
