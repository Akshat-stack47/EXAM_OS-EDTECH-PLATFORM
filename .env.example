# =============================================================================
# ExamOS — Environment Variables
# Copy this to .env and fill in your values (never commit .env to VCS)
# =============================================================================

# ---- App ----
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="ExamOS"

# ---- Database (Supabase PostgreSQL via Prisma Accelerate) ----
# DATABASE_URL uses Prisma Accelerate for connection pooling in serverless
# Get your Accelerate URL from https://console.prisma.io
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=your_accelerate_api_key"
# DIRECT_URL is used only for prisma migrate (direct DB connection, bypasses Accelerate)
DIRECT_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ---- Supabase Auth ----
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret-change-in-production"

# ---- Upstash Redis (rate limiting + queues) ----
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"
REDIS_URL="rediss://default:password@your-region.upstash.io:6379"

# ---- Sentry Error Tracking ----
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="exam-os"
SENTRY_PROJECT="exam-os"

# ---- PostHog Analytics ----
NEXT_PUBLIC_POSTHOG_KEY="phc_your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ---- Axiom Logging ----
AXIOM_TOKEN="your-axiom-token"
AXIOM_DATASET="exam-os-logs"
NEXT_PUBLIC_AXIOM_URL="https://api.axiom.co"

# ---- Typesense Search ----
TYPESENSE_API_KEY="your-api-key"
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8108"
TYPESENSE_PROTOCOL="http"

# ---- Resend (Email) ----
RESEND_API_KEY="re_your-resend-api-key"

# ---- MSG91 (SMS) ----
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="EXAMOS"

# ---- Razorpay (Payments) ----
RAZORPAY_KEY_ID="rzp_your-key-id"
RAZORPAY_KEY_SECRET="your-key-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_your-key-id"

# ---- Health Survey Encryption ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Keep this secret! Rotate quarterly!
HEALTH_ENCRYPTION_KEY="change-me-to-a-32-char-hex-key-here"

# ---- Database Read Replica (Supabase Pro) ----
# Used for analytics/reporting queries — prevents heavy reports from killing primary DB
DATABASE_REPLICA_URL="postgresql://postgres:password@db-replica.supabase.co:5432/postgres"

# ---- OpenAI ----
OPENAI_API_KEY="sk-your-openai-api-key"

# ---- Feature Flags ----
NEXT_PUBLIC_FEATURE_AI_GRADING="true"
NEXT_PUBLIC_FEATURE_LIVE_CLASSES="true"
NEXT_PUBLIC_FEATURE_PARENT_DASHBOARD="true"
